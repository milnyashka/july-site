# Supabase — https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public site URL (required for Cryptomus webhooks — not localhost in production)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Cryptomus — balance top-ups only — https://cryptomus.com
CRYPTOMUS_MERCHANT_ID=your-merchant-uuid
CRYPTOMUS_API_KEY=your-payment-api-key

# Platega — SBP QR top-ups — https://platega.io
# Callback URL in merchant LK: https://your-domain.com/api/webhooks/platega
PLATEGA_MERCHANT_ID=your-merchant-uuid
PLATEGA_API_KEY=your-x-secret-api-key

# Manual balance top-up admin panel — /ru/admin
ADMIN_PASSWORD=your-strong-secret-password